{% extends 'base.html.twig' %}

{% block title %}Income{% endblock %}

{% block body %}

<div class="form">
    <h1>Income</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ income.id }}</td>
            </tr>
            <tr>
                <th>Date</th>
                <td>{{ income.date ? income.date|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ income.name }}</td>
            </tr>
            <tr>
                <th>Type</th>
                <td>{{ income.type }}</td>
            </tr>
            <tr>
                <th>Amount</th>
                <td>{{ income.amount }}</td>
            </tr>
        </tbody>
    </table>

</div>

    {{ include('income/_delete_form.html.twig') }}
{% endblock %}
